{
  "expo": {
    "name": "CleanCheck",
    "slug": "cleancheck",
    "scheme": "cleancheck",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "CleanCheck needs your camera to scan barcodes and product labels."
        }
      ]
    ],
    "newArchEnabled": false
  }
}
