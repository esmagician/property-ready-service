{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "property-ready-service",
  "main": "./worker/index.js",
  "compatibility_date": "2026-07-01",
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true
    }
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
